{
  "name": "personalkb-electron",
  "version": "0.2.0",
  "description": "PersonalKB Desktop Shell",
  "main": "main.js",
  "scripts": {
    "start": "electron . --dev",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.personalkb.app",
    "productName": "PersonalKB",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  }
}
